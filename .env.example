JWT_SECRET=generate-with-node-e-crypto-randomBytes-32-toString-hex
PORT=3001
NODE_ENV=development
OPENAI_API_KEY=sk-your-key
DATABASE_PATH=./data/astrology.db

# Admin secret for the GET /api/analytics/funnel endpoint.
# If absent or empty, the endpoint returns 503 (endpoint_not_configured) to
# prevent silent fail-open behavior. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pass via the x-analytics-secret request header.
ANALYTICS_ADMIN_SECRET=
